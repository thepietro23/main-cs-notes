   "source": [
    "# Swap two numbers\n",
    "\n",
    "a = 10\n",
    "b = 2\n",
    "\n",
    "print(\"Before swap:\", a, b)\n",
    "\n",
    "a = a ^ b\n",
    "b = a ^ b\n",
    "a = a ^ b\n",
    "\n",
    "print(\"After swap:\", a, b)"
